{
  "name": "veblen-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:backend": "node backend/server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "npx prisma generate --schema=backend/prisma/schema.prisma && next build",
    "start": "sh -c 'npx prisma db push --schema=backend/prisma/schema.prisma && node backend/server.js & next start -p ${PORT:-3000}'",
    "lint": "eslint",
    "db:generate": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=backend/prisma/schema.prisma",
    "db:deploy": "npx prisma migrate deploy --schema=backend/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@base-ui/react": "^1.3.0",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "next": "16.2.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "prisma": "^6.19.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
