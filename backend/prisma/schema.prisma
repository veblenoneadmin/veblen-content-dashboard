generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Auth ─────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  password     String
  role         String    @default("ADMIN")
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ── Content ───────────────────────────────────────────────

model Post {
  id            String    @id @default(cuid())
  title         String
  caption       String?   @db.Text
  platform      String
  type          String
  status        String    @default("In Progress")
  scheduledDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([platform])
  @@index([status])
}

model GeneratedArticle {
  id          String   @id @default(cuid())
  topic       String
  articleText String   @db.LongText
  tone        String   @default("Authoritative")
  mood        String   @default("News Report")
  wordCount   Int      @default(0)
  sourceUrls  String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Competitor {
  id            String   @id @default(cuid())
  name          String   @unique
  category      String
  youtube       Int      @default(0)
  instagram     Int      @default(0)
  linkedin      Int      @default(0)
  posts         Int      @default(0)
  avgEngagement Float    @default(0)
  trend         String   @default("flat")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model NewsItem {
  id        String   @id @default(cuid())
  title     String
  summary   String   @db.Text
  source    String
  url       String   @db.Text
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([source])
  @@index([createdAt])
}

model NewsSource {
  id         String   @id @default(cuid())
  name       String   @unique
  type       String   @default("url")   // url | api | webhook
  endpoint   String?  @db.Text
  apiKey     String?  @db.Text
  webhookId  String?
  createdAt  DateTime @default(now())

  @@index([name])
}

model CreatorSource {
  id        String   @id @default(cuid())
  name      String
  platform  String   // TikTok | Instagram | YouTube | Other
  type      String   @default("url")  // url | api | webhook
  endpoint  String?  @db.Text
  apiKey    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([platform])
}
