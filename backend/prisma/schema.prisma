generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Auth ─────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  password     String
  role         String    @default("ADMIN")
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ── Content ───────────────────────────────────────────────

model Post {
  id            String    @id @default(cuid())
  title         String
  caption       String?   @db.Text
  platform      String
  type          String
  status        String    @default("In Progress")
  scheduledDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([platform])
  @@index([status])
}

model GeneratedArticle {
  id          String   @id @default(cuid())
  topic       String
  articleText String   @db.LongText
  tone        String   @default("Authoritative")
  mood        String   @default("News Report")
  wordCount   Int      @default(0)
  sourceUrls  String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Competitor {
  id            String   @id @default(cuid())
  name          String   @unique
  category      String
  youtube       Int      @default(0)
  instagram     Int      @default(0)
  linkedin      Int      @default(0)
  posts         Int      @default(0)
  avgEngagement Float    @default(0)
  trend         String   @default("flat")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model NewsItem {
  id        String   @id @default(cuid())
  title     String
  summary   String   @db.Text
  source    String
  url       String   @db.Text
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([source])
  @@index([createdAt])
}

model NewsSource {
  id         String   @id @default(cuid())
  name       String   @unique
  type       String   @default("url")   // url | api | webhook
  endpoint   String?  @db.Text
  apiKey     String?  @db.Text
  webhookId  String?
  createdAt  DateTime @default(now())

  @@index([name])
}

model CreatorSource {
  id        String   @id @default(cuid())
  name      String
  platform  String   // TikTok | Instagram | YouTube | Other
  type      String   @default("url")  // url | api | webhook
  endpoint  String?  @db.Text
  apiKey    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([platform])
}

model FrameworkTag {
  id                 String   @id @default(cuid())
  postId             String   // post_url or external ID
  hookType           String
  bodyStructure      String
  ctaPattern         String
  naturalDescription String?  @db.Text
  analysisDate       String
  createdAt          DateTime @default(now())

  @@index([postId(length: 191)])
  @@index([analysisDate])
}

model WeeklyReport {
  id                        String   @id @default(cuid())
  weekStart                 String
  topHooksJson              String?  @db.LongText
  topFrameworksJson         String?  @db.LongText
  trendInsights             String?  @db.LongText
  strategyRecommendations   String?  @db.LongText
  deltaFromLastWeek         String?  @db.LongText
  optimalPostingSchedule    String?  @db.LongText
  contentSplitRecommendation String? @db.LongText
  actionItems               String?  @db.LongText
  rawReport                 String?  @db.LongText
  createdAt                 DateTime @default(now())

  @@index([createdAt])
}

model ContentApproval {
  id               String    @id @default(cuid())
  contentId        String    @unique  // e.g. VID-1234-ABCD
  title            String
  type             String    // video | carousel
  status           String    @default("Pending Review")  // Pending Review | Approved | Rejected | Scheduled
  scriptCopy       String?   @db.LongText
  tiktokCaption    String?   @db.Text
  instagramCaption String?   @db.Text
  facebookCaption  String?   @db.Text
  platform         String?   // selected at approval time
  caption          String?   @db.Text  // selected at approval time
  giveawayAttached Boolean   @default(false)
  giveawayLink     String?   @db.Text
  triggerWord      String?
  referenceVideo   String?   @db.Text
  frameworkUsed    String?
  scheduledDate    String?
  approvedBy       String?
  notes            String?   @db.Text
  processed        Boolean   @default(false)
  generatedAt      DateTime  @default(now())
  approvedAt       DateTime?

  @@index([status])
  @@index([processed])
  @@index([generatedAt])
}

model SocialSource {
  id          String   @id @default(cuid())
  platform    String   // YouTube | Instagram | LinkedIn | Twitter/X | TikTok | Other
  handle      String
  url         String   @db.Text
  status      String   @default("pending")  // connected | disconnected | pending
  followers   Int      @default(0)
  lastSync    String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([platform])
  @@index([status])
}

model CreatorPost {
  id               String    @id @default(cuid())
  creatorName      String
  platform         String
  postUrl          String    @db.Text
  postDate         DateTime?
  views            Int       @default(0)
  likes            Int       @default(0)
  commentsCount    Int       @default(0)
  shares           Int       @default(0)
  saves            Int       @default(0)
  caption          String?   @db.Text
  hashtags         String?   @db.Text
  audio            String?
  durationSeconds  Int       @default(0)
  engagementRate   Float     @default(0)
  videoDownloadUrl String?   @db.Text
  transcript       String?   @db.LongText
  scrapedAt        DateTime  @default(now())

  @@index([creatorName])
  @@index([platform])
  @@index([engagementRate])
  @@index([scrapedAt])
}
