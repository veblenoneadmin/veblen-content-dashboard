generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Auth ─────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  password     String
  role         String    @default("ADMIN")
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ── Content ───────────────────────────────────────────────

model Post {
  id            String    @id @default(cuid())
  title         String
  caption       String?   @db.Text
  platform      String
  type          String
  status        String    @default("In Progress")
  scheduledDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([platform])
  @@index([status])
}

model GeneratedArticle {
  id          String   @id @default(cuid())
  topic       String
  articleText String   @db.LongText
  tone        String   @default("Authoritative")
  mood        String   @default("News Report")
  wordCount   Int      @default(0)
  sourceUrls  String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Competitor {
  id        String   @id @default(cuid())
  name      String
  category  String
  youtube   String?
  instagram String?
  linkedin  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsItem {
  id        String   @id @default(cuid())
  title     String
  summary   String   @db.Text
  source    String
  url       String   @db.Text
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([source])
  @@index([createdAt])
}
